<?xml version="1.0" encoding="utf-8" ?>
<local:AppPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:local="clr-namespace:IndoorCO2MapAppV2.Pages"
               xmlns:ui="clr-namespace:IndoorCO2MapAppV2.UIUtility"
               x:Class="IndoorCO2MapAppV2.Pages.DebugSensorPage"
               Title="Sensor Debug">

    <!-- Resources -->
    <local:AppPage.Resources>
        <ResourceDictionary>
            <ui:BooleanToTextConverter x:Key="ScanTextConverter"
                                       TrueText="Stop Scan"
                                       FalseText="Search for Bluetooth Devices"/>
            <ui:NullToBoolConverter x:Key="NullToBoolConverter"/>
        </ResourceDictionary>
    </local:AppPage.Resources>

    <VerticalStackLayout Padding="10" Spacing="10">

        <Button Text="Debug Menu"
                Clicked="OnNavigateClicked"
                CommandParameter="///debugMainMenu"
                HorizontalOptions="Fill"/>

        <Label Text="Select Monitor Type:" FontAttributes="Bold"/>
        <Picker x:Name="MonitorTypePicker"
                Title="Select monitor"
                HorizontalOptions="Fill"
                SelectedIndexChanged="MonitorTypePicker_SelectedIndexChanged"/>

        <!-- Scan button -->
        <Button x:Name="ScanButton"
                Text="{Binding IsScanning, Converter={StaticResource ScanTextConverter}}"
                Clicked="OnSearchBluetoothDevicesClicked"
                HorizontalOptions="Fill"/>

        <Button x:Name="RetrieveDataFromMonitorButton"
                Text="Retrieve Data from Sensor"
                Clicked="OnRetrieveDataFromMonitorClicked"
                HorizontalOptions="Fill"/>
        <Button x:Name="GetDataRepeatedlyButton"
        Text="Retrieve Data from Sensor repeatedly"
        Clicked="OnRetrieveDataFromMonitorContinouslyClicked"
        HorizontalOptions="Fill"/>
        <Button x:Name="SaveLogToFileButton"
Text="Safe Log to File"
Clicked="SaveLogToFile"
HorizontalOptions="Fill"/>

        <!-- List with all discovered BLE Devices 
        <CollectionView x:Name="BluetoothDevicesList"
                        SelectionMode="Single"
                        HeightRequest="200"
                        VerticalScrollBarVisibility="Always">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="Gray"
                            StrokeShape="RoundRectangle 5"
                            Padding="5"
                            Margin="2">
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView> -->

        <Picker x:Name="DevicePicker"
        Title="Select Device" />

        <Label Text="On Windows, need to manually pair device for some results - iOS/Android trigger pairing if trying to read/write characteristics requiring it"/>
        <!-- CO2 and interval labels -->
        <Label Text="{Binding CurrentCO2, StringFormat='Current CO₂ Value: {0}'}"/>
        <Label Text="{Binding MeasurementInterval, StringFormat='Measurement Interval: {0} sec'}"/>

        <Label Text="CO₂ History" FontAttributes="Bold"/>
        <CollectionView ItemsSource="{Binding Co2History}"
                HeightRequest="200">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Label Text="{Binding}" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Details panel for selected device -->
        <Border x:Name="SelectedDeviceDetails"
                Stroke="Gray"
                StrokeShape="RoundRectangle 5"
                Padding="10"
                IsVisible="{Binding SelectedDevice, Converter={StaticResource NullToBoolConverter}}"
                Margin="5">
            <VerticalStackLayout>
                <Label Text="{Binding SelectedDevice.Name, StringFormat='Name: {0}'}"
                       FontAttributes="Bold"/>
                <Label Text="{Binding SelectedDevice.Id, StringFormat='Id: {0}'}"
                       FontSize="12" TextColor="Gray"/>
                <Label Text="{Binding SelectedDevice.Rssi, StringFormat='RSSI: {0}'}"
                       FontSize="12" TextColor="DarkGray"/>
                <Label Text="{Binding SelectedDevice.AdvertisementInfo, StringFormat='Advertisement: {0}'}"
                       FontSize="10"/>
            </VerticalStackLayout>
        </Border>

        <Label Text="{Binding IsScanning, StringFormat='Scanning: {0}'}"
               FontAttributes="Italic"
               HorizontalOptions="Center"/>
    </VerticalStackLayout>
</local:AppPage>
