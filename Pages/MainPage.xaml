<?xml version="1.0" encoding="utf-8" ?>
<local:AppPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:IndoorCO2MapAppV2.Pages"
             xmlns:t="clr-namespace:IndoorCO2MapAppV2.Resources.Strings"
             xmlns:ui="clr-namespace:IndoorCO2MapAppV2.UIUtility"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:c="clr-namespace:IndoorCO2MapAppV2.Controls"
             x:Class="IndoorCO2MapAppV2.Pages.MainPage"
             Title="Home">

   <local:AppPage.Resources>
       <ResourceDictionary>
           <ui:ExpandButtonTextConverter x:Key="ExpandButtonTextConverter"/>
           <ui:InvertBooleanConverter x:Key="InvertBooleanConverter"/>
           <ui:LocationDisplayConverter x:Key="LocationDisplayConverter" />
           <ui:BooleanToTextConverter x:Key="FetchButtonTextConverter"
                      TrueText="Fetching Data..."
                      FalseText="Search Buildings"/>
       </ResourceDictionary>
   </local:AppPage.Resources>


    <Grid>

    <!-- Success banner (overlays content, slides in from top) -->
    <Border x:Name="SuccessBanner"
            BackgroundColor="#4CAF50"
            IsVisible="False"
            VerticalOptions="Start"
            HorizontalOptions="Fill"
            Margin="20,60,20,0"
            Padding="20,28"
            ZIndex="10">
        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
        <Label Text="✓  Submission Successful"
               TextColor="White"
               FontSize="15"
               FontAttributes="Bold"
               HorizontalOptions="Center" />
    </Border>

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="14">


            <!-- ===== Card 1: Sensor ===== -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">

                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Picker x:Name="CO2MonitorPicker"
                                Grid.Column="0"
                                Title="{x:Static t:Localisation.MonitorSelectionLabel}"/>
                        <Button x:Name="RefreshButton"
                                Grid.Column="1"
                                Text="↺"
                                Clicked="OnRefreshSensorListClicked"
                                Style="{StaticResource SecondaryButtonStyle}"
                                FontSize="22"
                                WidthRequest="44"
                                HeightRequest="44"
                                Padding="0"
                                Margin="8,0,0,0"
                                IsVisible="{Binding Sensor.IsScanning, Converter={StaticResource InvertBooleanConverter}}" />

                        <ActivityIndicator
                                Grid.Column="1"
                                IsRunning="{Binding Sensor.IsScanning}"
                                IsVisible="{Binding Sensor.IsScanning}"
                                WidthRequest="44"
                                HeightRequest="44"
                                Margin="8,0,0,0"
                                VerticalOptions="Center"
                                HorizontalOptions="Center" />
                    </Grid>

                    <!-- Sensor status chip -->
                    <Border Stroke="{AppThemeBinding Light={StaticResource DividerColor}, Dark={StaticResource DividerColorDark}}"
                            StrokeThickness="1"
                            BackgroundColor="Transparent"
                            Padding="10,5"
                            HorizontalOptions="Start">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <HorizontalStackLayout Spacing="7" VerticalOptions="Center">
                            <BoxView Color="{Binding Sensor.StatusDotColor}"
                                     WidthRequest="8" HeightRequest="8" CornerRadius="4"
                                     VerticalOptions="Center" />
                            <Label Text="{Binding Sensor.SelectedDeviceStatusText}"
                                   FontSize="13" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </Border>


            <!-- ===== Card 2: Building search ===== -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">

                    <Label x:Name="LabelSearchRange" Text="{x:Static t:Localisation.SearchRangeLabel}" FontSize="14" />
                    <HorizontalStackLayout x:Name="SearchRangeStackLayout" Spacing="10" VerticalOptions="Start">
                        <Label Text="100m" VerticalOptions="Center" />
                        <RadioButton
                            x:Name="RadioButton100m"
                            GroupName="SearchRange"
                            VerticalOptions="Center"
                            CheckedChanged="OnSearchRangeChanged"
                            IsChecked="True" />
                        <Label Text="250m" VerticalOptions="Center" />
                        <RadioButton
                            x:Name="RadioButton250m"
                            GroupName="SearchRange"
                            VerticalOptions="Center"
                            CheckedChanged="OnSearchRangeChanged" />
                    </HorizontalStackLayout>

                    <Grid x:Name="LocationUpdateGrid" ColumnDefinitions="3*,1*" HorizontalOptions="Fill" ColumnSpacing="10">
                        <Button
                            x:Name="UpdateLocationsButton"
                            Text="{Binding BuildingSearch.SearchButtonText}"
                            HorizontalOptions="Fill"
                            Clicked="OnSearchBuildingsClicked"
                            IsEnabled="{Binding BuildingSearch.CanSearch}"
                            Grid.Column="0" />
                        <Button
                            x:Name="GetCachedLocationsButton"
                            Text="📁"
                            FontSize="20"
                            Clicked="OnGetCachedLocationsClicked"
                            IsEnabled="{Binding BuildingSearch.HasValidGPS}"
                            HorizontalOptions="Fill"
                            Grid.Column="1" />
                    </Grid>

                    <HorizontalStackLayout
                        Spacing="10"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        IsVisible="{Binding FetchState.IsFetching}">
                        <ActivityIndicator
                            IsRunning="{Binding FetchState.IsFetching}"
                            VerticalOptions="Center"
                            WidthRequest="20"
                            HeightRequest="20" />
                        <Label
                            Text="{Binding BuildingSearch.Status}"
                            FontSize="14"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Label
                        Text="{Binding FetchState.LastError}"
                        TextColor="{AppThemeBinding Light={StaticResource ErrorColor}, Dark={StaticResource ErrorColorDark}}"
                        FontSize="13"
                        HorizontalOptions="Center"
                        IsVisible="{Binding FetchState.LastFailed}" />

                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center" HorizontalOptions="Fill">
                        <Border
                            BackgroundColor="Transparent"
                            Stroke="{AppThemeBinding Light={StaticResource DividerColor}, Dark={StaticResource DividerColorDark}}"
                            StrokeThickness="{OnPlatform iOS=2, Android=0}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4"/>
                            </Border.StrokeShape>
                            <Picker
                                ItemsSource="{Binding BuildingSearch.Buildings}"
                                SelectedItem="{Binding BuildingSearch.SelectedBuilding}"
                                ItemDisplayBinding="{Binding Converter={StaticResource LocationDisplayConverter}}" />
                        </Border>
                        <Label Grid.Column="1"
                               Text="★"
                               TextColor="{Binding BuildingSearch.StarColor}"
                               FontSize="30"
                               VerticalOptions="Center"
                               HorizontalOptions="End"
                               Margin="8,0,0,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BuildingSearch.ToggleFavouriteCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <c:LabeledSegmentedControl Label="" Items="{Binding Settings.SortModes}"
                                               SelectedItem="{Binding Settings.DefaultSortMode, Mode=OneTime}"
                                               SelectionChangedCommand="{Binding BuildingSearch.SortModeChangedCommand}"
                                               IsVisible="{Binding Settings.DisplaySortingModeToggle}" />

                    <Entry x:Name="FilterEntry"
                        Placeholder="{x:Static t:Localisation.MainMenuResultFilterPlaceholderText}"
                        Text="{Binding BuildingSearch.FilterText}"
                        IsVisible="{Binding Settings.DisplayBuildingFilterInputField}" />

                </VerticalStackLayout>
            </Border>


            <!-- ===== Card 3: Recording ===== -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">

                    <Button Text="{x:Static t:Localisation.MainMenuButtonStartBuildingRecording}"
                        Command="{Binding StartBuildingRecordingCommand}"
                        IsEnabled="{Binding CanStartBuildingRecording}" />

                    <Label Text="{Binding StartRecordingBlockedReason}"
                           IsVisible="{Binding IsStartRecordingBlocked}"
                           FontSize="12"
                           TextColor="Gray"
                           HorizontalOptions="Center" />

                    <c:LabeledSwitch Text="{x:Static t:Localisation.MainMenuPrerecordingSwitchText}" IsToggled="{Binding Settings.EnablePreRecording}" />

                    <Button
                        x:Name="ManualResumeButton"
                        Text="Resume Recording"
                        IsVisible="False"
                        Clicked="OnManualResumeClicked" />

                </VerticalStackLayout>
            </Border>


            <!-- ===== Navigation ===== -->
            <Button Text="{x:Static t:Localisation.MainMenuSettingsButtonText}"
                    Clicked="OnNavigateClicked"
                    CommandParameter="///settings"
                    Style="{StaticResource TonalButtonStyle}"
                    HorizontalOptions="Fill"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Text="News"
                        Clicked="OnNavigateClicked"
                        CommandParameter="///news"
                        Style="{StaticResource TonalButtonStyle}"
                        HorizontalOptions="Fill"
                        Grid.Column="0"/>
                <Button Text="Statistics"
                        Clicked="OnNavigateClicked"
                        CommandParameter="///statistics"
                        Style="{StaticResource TonalButtonStyle}"
                        HorizontalOptions="Fill"
                        Grid.Column="1"/>
            </Grid>

            <Button Text="{x:Static t:Localisation.MainMenuHistoryButtonText}"
                    Clicked="OnNavigateClicked"
                    CommandParameter="///history"
                    Style="{StaticResource TonalButtonStyle}"
                    HorizontalOptions="Fill"
                    IsVisible="{Binding HasRecordings}"/>

            <!--
            <Button Text="Start Transit Recording" Clicked="OnNavigateClicked" CommandParameter="///transit" HorizontalOptions="Fill"/>
            <Button Text="Map" Clicked="OnNavigateClicked" CommandParameter="///map" HorizontalOptions="Fill"/>
            <Button Text="Debug Menu" Clicked="OnNavigateClicked" CommandParameter="///debugMainMenu" HorizontalOptions="Fill"/>
            -->

        </VerticalStackLayout>
    </ScrollView>

    </Grid>

</local:AppPage>
