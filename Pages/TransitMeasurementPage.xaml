<?xml version="1.0" encoding="utf-8" ?>
<local:AppPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:local="clr-namespace:IndoorCO2MapAppV2.Pages"
               xmlns:t="clr-namespace:IndoorCO2MapAppV2.Resources.Strings"
               xmlns:controls="clr-namespace:IndoorCO2MapAppV2.Controls"
               xmlns:enums="clr-namespace:IndoorCO2MapAppV2.Enumerations"
               xmlns:ui="clr-namespace:IndoorCO2MapAppV2.UIUtility"
               x:Class="IndoorCO2MapAppV2.Pages.TransitMeasurementPage"
               Title="Transit Measurement">

    <local:AppPage.Resources>
        <ResourceDictionary>
            <ui:LocationDisplayConverter x:Key="LocationDisplayConverter" />
        </ResourceDictionary>
    </local:AppPage.Resources>

    <ScrollView>
    <VerticalStackLayout Padding="30" Spacing="25">

    <Label x:Name="MeasuredLocationLabel" Text="{x:Static t:Localisation.TransitRouteStationPlaceholder}"
           Style="{StaticResource PageTitleStyle}"/>

    <!-- Chart + slider share the grid area. Slider spans both rows so its
         transparent hit-extensions cover the full chart height. Chart sits
         on top visually (added last = higher z-order) but is InputTransparent
         so touches fall through to the slider's extended hit areas. -->
    <Grid RowDefinitions="150, 55">
        <controls:RangeSlider
            x:Name="TrimSlider"
            Grid.Row="0"
            Grid.RowSpan="2"
            RangeChanged="OnTrimChanged"
            Minimum="0"
            Maximum="20"
            LowerValue="0"
            UpperValue="20"
            ThumbSize="30"
            TrackHeight="15"
            TrackColor="{AppThemeBinding Light={StaticResource DividerColor}, Dark={StaticResource DividerColorDark}}"
            HighlightColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
            WidthRequest="375" />
        <controls:LineChartView x:Name="lineChartView"
                                Grid.Row="0"
                                HeightRequest="150"
                                WidthRequest="400"
                                InputTransparent="True" />
    </Grid>

        <!-- Destination (optional) -->
        <Border Style="{StaticResource CardBorderStyle}">
            <VerticalStackLayout Spacing="10">
                <Label Text="{x:Static t:Localisation.TransitDestinationLabel}" Style="{StaticResource SectionLabelStyle}" />
                <Button x:Name="SearchEndpointButton"
                        Text="{x:Static t:Localisation.TransitSearchNearbyStops}"
                        Clicked="OnSearchEndpointClicked"
                        HorizontalOptions="Fill" />
                <ActivityIndicator x:Name="EndpointSearchIndicator"
                                   IsVisible="False" IsRunning="False"
                                   HorizontalOptions="Center" />
                <Label x:Name="EndpointStatusLabel"
                       IsVisible="False"
                       FontSize="13" TextColor="Gray"
                       HorizontalOptions="Center" />
                <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center" HorizontalOptions="Fill">
                    <Border Grid.Column="0"
                            x:Name="EndpointPickerBorder"
                            Stroke="{AppThemeBinding Light={StaticResource DividerColor}, Dark={StaticResource DividerColorDark}}"
                            StrokeThickness="{OnPlatform iOS=2, Android=0}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                        <Picker x:Name="EndpointPicker"
                                ItemDisplayBinding="{Binding Converter={StaticResource LocationDisplayConverter}}"
                                SelectedIndexChanged="OnEndpointPickerSelectionChanged"
                                Title="{x:Static t:Localisation.TransitSelectDestination}" />
                    </Border>
                    <Label x:Name="EndpointStarLabel"
                           Grid.Column="1"
                           Text="★"
                           TextColor="#BDBDBD"
                           FontSize="30"
                           VerticalOptions="Center"
                           HorizontalOptions="End"
                           Margin="8,0,0,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnEndpointStarTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
            <VerticalStackLayout Spacing="12">

                <!-- Windows open? -->
                <Label Text="{x:Static t:Localisation.RadioButtonLabelOpenDoorsWindows}"
                       Style="{StaticResource SectionLabelStyle}" />

                <HorizontalStackLayout Spacing="5">
                    <RadioButton
                        x:Name="WindowsUnknownRb"
                        Content="{x:Static t:Localisation.RadioNoData}"
                        IsChecked="True"
                        GroupName="TransitWindowsGroup"
                        Value="{x:Static enums:TriState.Unknown}"
                        CheckedChanged="OnWindowsChanged" />
                    <RadioButton
                        x:Name="WindowsYesRb"
                        Content="{x:Static t:Localisation.RadioYes}"
                        GroupName="TransitWindowsGroup"
                        Value="{x:Static enums:TriState.Yes}"
                        CheckedChanged="OnWindowsChanged" />
                    <RadioButton
                        x:Name="WindowsNoRb"
                        Content="{x:Static t:Localisation.RadioNo}"
                        GroupName="TransitWindowsGroup"
                        Value="{x:Static enums:TriState.No}"
                        CheckedChanged="OnWindowsChanged" />
                </HorizontalStackLayout>

                <!-- Ventilation / A/C active? -->
                <Label Text="{x:Static t:Localisation.RadioButtonLabelVentilationSystem}"
                       Style="{StaticResource SectionLabelStyle}" />

                <HorizontalStackLayout Spacing="5">
                    <RadioButton
                        x:Name="VentilationUnknownRb"
                        Content="{x:Static t:Localisation.RadioNoData}"
                        IsChecked="True"
                        GroupName="TransitVentilationGroup"
                        Value="{x:Static enums:TriState.Unknown}"
                        CheckedChanged="OnVentilationChanged" />
                    <RadioButton
                        x:Name="VentilationYesRb"
                        Content="{x:Static t:Localisation.RadioYes}"
                        GroupName="TransitVentilationGroup"
                        Value="{x:Static enums:TriState.Yes}"
                        CheckedChanged="OnVentilationChanged" />
                    <RadioButton
                        x:Name="VentilationNoRb"
                        Content="{x:Static t:Localisation.RadioNo}"
                        GroupName="TransitVentilationGroup"
                        Value="{x:Static enums:TriState.No}"
                        CheckedChanged="OnVentilationChanged" />
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>

        <!-- Custom Note -->
        <Border Style="{StaticResource CardBorderStyle}">
            <VerticalStackLayout Spacing="10">
                <Label Text="{x:Static t:Localisation.RecordingCustomNoteLabelText}"
                       Style="{StaticResource SectionLabelStyle}" />
                <Editor
                    x:Name="NoteEditor"
                    Placeholder="{x:Static t:Localisation.RecordingCustomNotPlaceholderText}"
                    AutoSize="TextChanges"
                    MinimumHeightRequest="80"
                    BackgroundColor="{AppThemeBinding Light={StaticResource InputBackground}, Dark={StaticResource InputBackgroundDark}}"
                    TextChanged="OnCustomNotesChanged" />
            </VerticalStackLayout>
        </Border>

        <Button x:Name="SubmitButton"
                Text="{x:Static t:Localisation.SubmitRecordingButton}"
                Clicked="OnSubmitRecordingClicked"
                HorizontalOptions="Fill" />

        <Button Text="{x:Static t:Localisation.CancelRecordingButton}"
                Style="{StaticResource SecondaryButtonStyle}"
                Clicked="OnCancelClicked"
                HorizontalOptions="Fill" />

    </VerticalStackLayout>
    </ScrollView>

</local:AppPage>
