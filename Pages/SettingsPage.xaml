<?xml version="1.0" encoding="utf-8" ?>
<local:AppPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:IndoorCO2MapAppV2.Pages"
             xmlns:c="clr-namespace:IndoorCO2MapAppV2.Controls"
             x:Class="IndoorCO2MapAppV2.Pages.SettingsPage"
             Title="Settings">

    <ScrollView>
    <VerticalStackLayout Padding="30" Spacing="14">

        <Button Text="Main Menu" Clicked="OnNavigateClicked" CommandParameter="///home" HorizontalOptions="Fill"/>

        <!--
        <Button Text="Sensor Debug" Clicked="OnNavigateClicked" CommandParameter="///sensorDebug" HorizontalOptions="Fill"/>
        <Button Text="Overpass Debug" Clicked="OnNavigateClicked" CommandParameter="///overpassDebug" HorizontalOptions="Fill"/>
        <Button Text="Building Recording Debug" Clicked="OnNavigateClicked" CommandParameter="///buildingRecordingDebug" HorizontalOptions="Fill"/>
        -->

        <!-- ===== Sensor ===== -->
        <Border Style="{StaticResource CardBorderStyle}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Sensor Filter" Style="{StaticResource SectionLabelStyle}" />
                <Entry
                    Text="{Binding SensorFilter}"
                    Placeholder="Only show sensors containing this string."
                    ClearButtonVisibility="WhileEditing" />
            </VerticalStackLayout>
        </Border>

        <!-- ===== Display ===== -->
        <Border Style="{StaticResource CardBorderStyle}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Display" Style="{StaticResource SectionLabelStyle}" />
                <c:LabeledSwitch Text="Show Building Sorting Toggle" IsToggled="{Binding DisplaySortingModeToggle}" />
                <c:LabeledSwitch Text="Show Building Search Filter" IsToggled="{Binding DisplayBuildingFilterInputField}" />
                <c:LabeledSegmentedControl Label="Default Sort Mode" Items="{Binding SortModes}" SelectedItem="{Binding DefaultSortMode}" />
            </VerticalStackLayout>
        </Border>

        <!-- ===== Recording ===== -->
        <Border Style="{StaticResource CardBorderStyle}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Recording" Style="{StaticResource SectionLabelStyle}" />
                <c:LabeledSwitch Text="Confirmation before Submitting Recording" IsToggled="{Binding ConfirmationBeforeRecordingUpload}" />
            </VerticalStackLayout>
        </Border>

        <!-- ===== Data ===== -->
        <Border Style="{StaticResource CardBorderStyle}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Data" Style="{StaticResource SectionLabelStyle}" />
                <c:LabeledSwitch Text="Use live location service (Overpass, updates every minute)" IsToggled="{Binding UseLiveLocationService}" />
                <c:LabeledSwitch Text="Enable Location Caching" IsToggled="{Binding EnableLocationCaching}" />
                <c:LabeledSegmentedControl Label="Cache Search Range Override"
                    Items="{Binding CacheRangeOverrideOptions}"
                    SelectedItem="{Binding CacheRangeOverride}" />
                <c:LabeledSwitch Text="Enable Local Recording History" IsToggled="{Binding EnableHistory}" />
                <Button Text="Delete Location Cache"
                        Clicked="OnDeleteLocationCacheClicked"
                        Style="{StaticResource SecondaryButtonStyle}"
                        TextColor="{AppThemeBinding Light={StaticResource ErrorColor}, Dark={StaticResource ErrorColorDark}}"
                        BorderColor="{AppThemeBinding Light={StaticResource ErrorColor}, Dark={StaticResource ErrorColorDark}}"
                        HorizontalOptions="Fill"/>
                <Button Text="Delete Local Recording History"
                        Clicked="OnDeleteRecordingHistoryClicked"
                        Style="{StaticResource SecondaryButtonStyle}"
                        TextColor="{AppThemeBinding Light={StaticResource ErrorColor}, Dark={StaticResource ErrorColorDark}}"
                        BorderColor="{AppThemeBinding Light={StaticResource ErrorColor}, Dark={StaticResource ErrorColorDark}}"
                        HorizontalOptions="Fill"/>
            </VerticalStackLayout>
        </Border>

        <!-- ===== Debug ===== -->
        <Border Style="{StaticResource CardBorderStyle}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Debug" Style="{StaticResource SectionLabelStyle}" />
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="Round GPS Position to 0.5°"
                           Grid.Column="0"
                           VerticalOptions="Center" />
                    <Switch x:Name="RoundGpsSwitch"
                            IsToggled="True"
                            Grid.Column="1"
                            Toggled="OnRoundGpsToggled" />
                </Grid>
                <Button Text="Copy Debug Log to Clipboard"
                        Clicked="OnCopyDebugLogClicked"
                        Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalOptions="Fill"/>
            </VerticalStackLayout>
        </Border>

    </VerticalStackLayout>
    </ScrollView>

</local:AppPage>
